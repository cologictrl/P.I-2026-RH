@startuml classes

title Diagrama de Classes - Entidades e Repositorios\nRHOS (RH Operation System)

left to right direction
skinparam dpi 180
skinparam shadowing false
skinparam defaultFontSize 13
skinparam classBackgroundColor #EFF6FF
skinparam classBorderColor #255F71
skinparam classHeaderBackgroundColor #255F71
skinparam classFontColor #1A1A1A
skinparam classHeaderFontColor #FFFFFF
skinparam classFontSize 12
skinparam classAttributeIconSize 0
skinparam interfaceBackgroundColor #FFF7ED
skinparam interfaceBorderColor #F48C68
skinparam interfaceHeaderBackgroundColor #F48C68
skinparam interfaceFontColor #1A1A1A
skinparam interfaceHeaderFontColor #FFFFFF
skinparam interfaceFontSize 12
skinparam ArrowColor #255F71
skinparam backgroundColor #FFFFFF

' ── Interfaces de Repositorio ────────────────────────────────────

interface ICandidatoRepositorio {
  +salvar(candidato: Candidato): Future<int>
  +salvarCompleto(candidato: Candidato): Future<int>
  +listarTodos(): Future<List<Candidato>>
  +buscarPorIdStr(idStr: String): Future<Candidato?>
  +buscarPorEmail(email: String): Future<Candidato?>
  +buscarPorCpf(cpf: String): Future<Candidato?>
  +listarHabilidadesStr(candidatoIdStr: String): Future<List<Habilidade>>
  +listarIdiomasStr(candidatoIdStr: String): Future<List<Idioma>>
  +listarExperienciasStr(candidatoIdStr: String): Future<List<Experiencia>>
  +listarFormacoesStr(candidatoIdStr: String): Future<List<Formacao>>
  +atualizarCampoStr(idStr, campo, valor): Future<void>
  +deletarPorIdStr(idStr: String): Future<void>
}

interface IVagaRepositorio {
  +salvar(vaga: Vaga): Future<int>
  +listarTodas(): Future<List<Vaga>>
  +listarPorStatus(status: String): Future<List<Vaga>>
  +buscarPorIdStr(idStr: String): Future<Vaga?>
  +deletarPorIdStr(idStr: String): Future<void>
  +atualizarStatusStr(idStr: String, status: String): Future<void>
}

interface IUsuarioRepositorio {
  +autenticar(email: String, senhaHash: String): Future<Usuario?>
  +buscarPorUid(uid: String): Future<Usuario?>
  +listarTodos(): Future<List<Usuario>>
  +salvar(usuario: Usuario): Future<int>
  +atualizarAtivoStr(uid: String, ativo: bool): Future<void>
}

interface ICandidaturaRepositorio {
  +salvar(candidatura: Candidatura): Future<int>
  +listarPorVagaStr(vagaIdStr: String): Future<List<Candidatura>>
  +listarPorCandidatoStr(candidatoIdStr: String): Future<List<Candidatura>>
  +atualizarStatusStr(idStr: String, status: String): Future<void>
  +atualizarScoreStr(idStr: String, score: double): Future<void>
  +deletarStr(idStr: String): Future<void>
}

' ── Implementacoes Firestore ─────────────────────────────────────

class CandidatoRepositorioFirestore {
  -{static} _colecao: String = "candidatos"
  -_db: FirebaseFirestore
  +buscarPorEmail(email: String): Future<Candidato?>
  +buscarPorCpf(cpf: String): Future<Candidato?>
  +buscarPorUsuarioUid(uid: String): Future<Candidato?>
  +buscarPorIdStr(idStr: String): Future<Candidato?>
  +deletarPorIdStr(idStr: String): Future<void>
  +atualizarCampoStr(idStr, campo, valor): Future<void>
}

class VagaRepositorioFirestore {
  -{static} _colecao: String = "vagas"
  -_db: FirebaseFirestore
  +buscarPorIdStr(idStr: String): Future<Vaga?>
  +deletarPorIdStr(idStr: String): Future<void>
  +atualizarStatusStr(idStr: String, status: String): Future<void>
}

class CandidaturaRepositorioFirestore {
  -{static} _colecao: String = "candidaturas"
  -_db: FirebaseFirestore
  +listarPorVagaStr(vagaIdStr: String): Future<List<Candidatura>>
  +atualizarStatusStr(idStr: String, status: String): Future<void>
  +atualizarScoreStr(idStr: String, score: double): Future<void>
  +deletarStr(idStr: String): Future<void>
}

class RankingRepositorioFirestore {
  -{static} _colecao: String = "rankings"
  -_db: FirebaseFirestore
  +salvar(vagaIdStr, candidatoIdStr, dados): Future<void>
  +buscar(vagaIdStr, candidatoIdStr): Future<Map?>
  +listarPorVaga(vagaIdStr): Future<List<Map>>
  +apagar(vagaIdStr, candidatoIdStr): Future<void>
  +apagarPorVaga(vagaIdStr): Future<void>
  +apagarPorCandidato(candidatoIdStr): Future<void>
}

class UsuarioRepositorioFirestore {
  -{static} _colecao: String = "usuarios"
  -_db: FirebaseFirestore
  -_auth: FirebaseAuth
  +buscarPorUid(uid: String): Future<Usuario?>
  +atualizarAtivoStr(uid: String, ativo: bool): Future<void>
}

class EntrevistaRepositorioFirestore {
  -{static} _colecao: String = "entrevistas"
  -_db: FirebaseFirestore
  +salvar(entrevista: Entrevista): Future<String?>
  +deletar(idStr: String): Future<void>
}

class RankingService {
  +calcularRanking(vaga, candidato, habilidades, idiomas, experiencias, formacoes): Future<Map?>
}

' ── Entidades ────────────────────────────────────────────────────

class Usuario {
  +idStr: String?
  +nome: String
  +email: String
  +perfil: String
  +ativo: bool
}

class Candidato {
  +idStr: String?
  +usuarioUid: String?
  +nome: String?
  +cpf: String?
  +email: String?
  +telefone: String?
  +resumo: String?
}

class Vaga {
  +idStr: String?
  +titulo: String
  +descricao: String?
  +status: String
  +requisitos: List<String>?
  +habilidades: List<String>?
  +softSkills: List<String>?
  +senioridade: String?
  +local: String?
  +modalidade: String?
  +salarioMin: double?
  +salarioMax: double?
}

class Candidatura {
  +idStr: String?
  +candidatoIdStr: String?
  +vagaIdStr: String?
  +score: double
  +status: String
}

class Entrevista {
  +idStr: String?
  +vagaIdStr: String?
  +candidatoIdStr: String?
  +dataHora: String
  +status: String
}

class Experiencia {
  +cargo: String?
  +empresa: String?
  +localidade: String?
  +modalidade: String?
  +dataInicio: String?
  +dataFim: String?
  +atual: bool
  +descricao: String?
}

class Habilidade {
  +nome: String
  +categoria: String
}

class Idioma {
  +nome: String
  +nivel: String
}

class Formacao {
  +instituicao: String?
  +curso: String?
  +nivel: String?
  +anoConclusao: String?
}

' ── Casos de Uso ─────────────────────────────────────────────────

class ListarCandidatos {
  -_repo: ICandidatoRepositorio
  +executar(): Future<List<Candidato>>
}

class SalvarCandidato {
  -_repo: ICandidatoRepositorio
  +executar(candidato: Candidato): Future<int>
}

class VerificarDuplicidade {
  -_repo: ICandidatoRepositorio
  +executar(cpf, email): Future<Candidato?>
}

class RanquearCandidatos {
  +calcularDetalhado(candidato, vaga): RankingDetalhado
}

class AutenticarUsuario {
  -_authService: FirebaseAuthService
  -_prefs: SharedPreferences
  +executar(email, senha): Future<Usuario?>
}

class GeminiOcrService {
  -{static} _apiKey: String
  -{static} _prompt: String
  +extrairDadosDosBytes(bytes, mimeType): Future<Map?>
}

class RankingDetalhado {
  +scoreTotal: double
  +scoresPorEixo: Map
  +gatingAprovado: bool
  +requisitosNaoAtendidos: List<String>
}

' ── Relacionamentos ──────────────────────────────────────────────

ICandidatoRepositorio    <|.. CandidatoRepositorioFirestore
IVagaRepositorio         <|.. VagaRepositorioFirestore
ICandidaturaRepositorio  <|.. CandidaturaRepositorioFirestore
IUsuarioRepositorio      <|.. UsuarioRepositorioFirestore

Candidatura "n" --> "1" Candidato
Candidatura "n" --> "1" Vaga

Candidato "1" *-- "n" Habilidade
Candidato "1" *-- "n" Idioma
Candidato "1" *-- "n" Experiencia
Candidato "1" *-- "n" Formacao

ListarCandidatos      --> ICandidatoRepositorio
SalvarCandidato       --> ICandidatoRepositorio
VerificarDuplicidade  --> ICandidatoRepositorio
MergeCandidato        --> ICandidatoRepositorio
RanquearCandidatos    --> IVagaRepositorio

@enduml
